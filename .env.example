
# Vitalia Spec Kit — Variáveis de otimização
OLLAMA_FLASH_ATTENTION=1          # Reduz uso de VRAM para KV-cache
NCBI_API_EMAIL=                   # Email para NCBI E-utilities (não requer cadastro)
GEMINI_API_KEY=                   # Chave API Gemini (fallback cloud)
DASHBOARD_SECRET_KEY=sua_senha_aqui

# -------------------------------------------------------------
# Perfis de Hardware por Nó (Tool Calling Adaptativo)
# -------------------------------------------------------------
# Modelo a usar em cada nó (sem hardcoding no código — Art. XII)
NO1_MODEL=llama3.2:3b             # Modelo do Nó 1 (notebook/CPU)
NO2_MODEL=qwen2.5-coder:7b        # Modelo do Nó 2 (servidor/GPU)
# Tool Calling nativo por nó:
# true  → GPU com 8GB+ VRAM, modelo suporta tool calling nativo
# false → CPU ou GPU limitada, usa Tool Bridge via Redis Streams
NO1_TOOL_CALLING_NATIVE=false     # Nó 1 (notebook sem GPU dedicada)
NO2_TOOL_CALLING_NATIVE=true      # Nó 2 (servidor com GTX 1060+)
# Timeout do Tool Bridge em segundos (padrão: 30)
TOOL_BRIDGE_TIMEOUT_SEC=30
